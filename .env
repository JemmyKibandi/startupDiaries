# ─────────────────────────────────────────────────────────────────────────────
# PIPELINE — environment variable template
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# Neon PostgreSQL — get these from neon.tech dashboard → Connection Details
# Use the "Pooled connection" string for DATABASE_URL (goes through PgBouncer)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Direct connection — used only by `prisma db push` / `prisma migrate`
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"
